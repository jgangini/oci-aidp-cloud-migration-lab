{
  "schema_version": 1,
  "project_id": "oci-aidp-cloud-migration-lab",
  "terraform": {
    "path": "infra/terraform",
    "package_oci_credentials": false
  },
  "capabilities": {
    "compartment_modes": ["new", "existing"],
    "requires_genai_region": false,
    "database_profile": "none"
  },
  "presentation": {
    "title": "OCI AIDP Cloud Migration Lab",
    "summary": "Deploys an OCI AI Data Platform laboratory with AIDP Workbench, one governed aidp-data bucket, Landing/Bronze/Silver/Gold prefixes, Identity Domains developer groups and a self-service HTTPS registration VM.",
    "tags": ["AIDP Workbench", "Medallion Storage", "Identity Domains", "Object Storage", "HTTPS VM"],
    "image": "/assets/blueprints/ai-data-platform-workbench-medallion-ba3242d5.png",
    "image_alt": "OCI AI Data Platform Workbench medallion architecture",
    "href": "https://github.com/jgangini/oci-aidp-cloud-migration-lab"
  },
  "form": {
    "fields": [
      {
        "name": "admin_username",
        "label": "Administrator username",
        "type": "text",
        "required": true,
        "default": "admin",
        "min_length": 3,
        "max_length": 64
      },
      {
        "name": "admin_password",
        "label": "Administrator password",
        "type": "password",
        "required": true,
        "secret": true,
        "min_length": 12,
        "max_length": 128,
        "transform": "pbkdf2_sha256"
      },
      {
        "name": "registration_code",
        "label": "Lab registration code",
        "type": "text",
        "required": true,
        "secret": true,
        "pattern": "^[A-Z]{4}-[0-9]{4}$",
        "min_length": 9,
        "max_length": 9,
        "transform": "uppercase_pbkdf2_sha256"
      },
      {
        "name": "ssh_allowed_cidr",
        "label": "Optional SSH CIDR",
        "type": "text",
        "required": false,
        "default": ""
      }
    ]
  },
  "outputs": [
    "application_url",
    "admin_url",
    "aidp_console_url",
    "compartment_ocid",
    "bucket_name",
    "objectstorage_namespace",
    "medallion_prefixes",
    "ai_data_platform_id",
    "default_workspace_name",
    "developer_group_ocid",
    "pending_group_ocid",
    "identity_domain_url",
    "instance_id",
    "public_ip",
    "vm_shape"
  ],
  "artifacts": ["aidp_lab_summary.json"],
  "preflight": {
    "entrypoint": "infra/terraform/preflight.py",
    "timeout_seconds": 60,
    "requires_oci_credentials": true,
    "output_inputs": ["home_region", "preferred_vm_shape"],
    "runtime_fields": [
      {
        "name": "home_region",
        "label": "OCI tenancy home region",
        "type": "text",
        "required": true,
        "pattern": "^[a-z]{2}-[a-z0-9-]+-[0-9]+$",
        "min_length": 8,
        "max_length": 64
      },
      {
        "name": "preferred_vm_shape",
        "label": "Selected VM shape",
        "type": "select",
        "required": true,
        "options": [
          {"value": "VM.Standard.E5.Flex", "label": "E5 Flex"},
          {"value": "VM.Standard.E4.Flex", "label": "E4 Flex"}
        ]
      }
    ]
  },
  "post_apply": {
    "entrypoint": "infra/terraform/hooks/post_apply.py",
    "timeout_seconds": 3600,
    "requires_oci_credentials": true
  }
}
