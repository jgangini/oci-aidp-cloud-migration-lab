REGISTRATION_CODE_HASH=pbkdf2_sha256$600000$BASE64_SALT$BASE64_DIGEST
IDENTITY_DOMAIN_URL=https://idcs-example.identity.oraclecloud.com
IDENTITY_DEVELOPER_GROUP_ID=replace-scim-group-id
