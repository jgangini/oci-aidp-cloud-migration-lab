{
  "schema_version": 1,
  "project_id": "oci-aidp-cloud-migration-lab",
  "terraform": {
    "path": "terraform",
    "package_oci_credentials": false
  },
  "capabilities": {
    "compartment_modes": ["new", "existing"],
    "requires_genai_region": false,
    "database_profile": "none"
  },
  "presentation": {
    "title": "OCI AI Data Platform Cloud Migration Lab",
    "summary": "Deploys a governed OCI data engineering laboratory: a VCN and HTTPS VM host registration and administration, AI Data Platform provides the shared workspace and Spark compute, and a private bucket implements Landing, Bronze, Silver, and Gold data layers. Identity Domains groups and IAM policies onboard lab users with controlled access to notebooks, workflows, and governed data.",
    "tags": ["VM", "VCN", "AI Data Platform", "Object Storage Bucket", "IAM Policies"],
    "image": "/assets/oci-aidp-cloud-migration-lab.png",
    "image_alt": "OCI AI Data Platform Cloud Migration Lab architecture",
    "href": "https://github.com/jgangini/oci-aidp-cloud-migration-lab"
  },
  "run_steps": [
    {"key": "queue", "label": "Queue"},
    {"key": "credentials", "label": "OCI credentials"},
    {"key": "compartment", "label": "Lab compartment"},
    {"key": "policies", "label": "Identity and IAM"},
    {"key": "stack", "label": "Resource Manager stack"},
    {"key": "plan", "label": "Terraform plan"},
    {"key": "apply", "label": "Terraform apply"},
    {"key": "network", "label": "VCN and public subnet"},
    {"key": "bucket", "label": "Medallion Object Storage"},
    {"key": "compute", "label": "Registration VM"},
    {"key": "application", "label": "AIDP workspace, catalog and RBAC"},
    {"key": "artifacts", "label": "Lab access summary"},
    {"key": "email", "label": "Access email"},
    {"key": "complete", "label": "Lab ready"}
  ],
  "form": {
    "fields": [
      {
        "name": "admin_username",
        "label": "Username",
        "type": "text",
        "required": true,
        "default": "admin",
        "min_length": 3,
        "max_length": 64
      },
      {
        "name": "admin_password",
        "label": "Password",
        "type": "password",
        "required": true,
        "secret": true,
        "min_length": 12,
        "max_length": 128,
        "transform": "pbkdf2_sha256"
      },
      {
        "name": "registration_code",
        "label": "Lab registration code",
        "type": "text",
        "required": true,
        "secret": true,
        "pattern": "^[A-Z]{4}-[0-9]{4}$",
        "min_length": 9,
        "max_length": 9,
        "transform": "uppercase_pbkdf2_sha256"
      }
    ]
  },
  "outputs": [
    "application_url",
    "admin_url",
    "aidp_workbench_url",
    "aidp_web_socket_endpoint",
    "tenancy_name",
    "identity_domain_name",
    "compartment_ocid",
    "bucket_name",
    "objectstorage_namespace",
    "medallion_prefixes",
    "ai_data_platform_id",
    "default_workspace_name",
    "developer_group_ocid",
    "pending_group_ocid",
    "provisioner_user_ocid",
    "provisioner_group_ocid",
    "home_region",
    "aidp_catalog_name",
    "aidp_shared_compute_name",
    "aidp_external_volume_count",
    "aidp_provisioner_ready",
    "identity_domain_url",
    "instance_id",
    "public_ip",
    "vm_shape"
  ],
  "artifacts": ["aidp_lab_summary.json"],
  "preflight": {
    "entrypoint": "terraform/k_preflight.py",
    "timeout_seconds": 60,
    "requires_oci_credentials": true,
    "output_inputs": ["home_region", "preferred_vm_shape", "availability_domain_index"],
    "runtime_fields": [
      {
        "name": "home_region",
        "label": "OCI tenancy home region",
        "type": "text",
        "required": true,
        "pattern": "^[a-z]{2}-[a-z0-9-]+-[0-9]+$",
        "min_length": 8,
        "max_length": 64
      },
      {
        "name": "preferred_vm_shape",
        "label": "Selected VM shape",
        "type": "select",
        "required": true,
        "options": [
          {"value": "VM.Standard.E5.Flex", "label": "E5 Flex"},
          {"value": "VM.Standard.E4.Flex", "label": "E4 Flex"},
          {"value": "VM.Standard.E3.Flex", "label": "E3 Flex (authorized fallback)"}
        ]
      },
      {
        "name": "availability_domain_index",
        "label": "Selected Availability Domain",
        "type": "number",
        "required": true,
        "min_length": 1,
        "max_length": 2
      }
    ]
  },
  "post_apply": {
    "entrypoint": "terraform/hooks/post_apply.py",
    "timeout_seconds": 3600,
    "requires_oci_credentials": true
  }
}
